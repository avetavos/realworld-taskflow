{
  // Cloudflare Worker (static assets) for the TaskFlow guide.
  // The site is built with Astro `base: '/taskflow'`, so the built files must be
  // served under a `/taskflow/` path. `npm run deploy` stages `dist/` into
  // `.cf-assets/taskflow/` and serves `.cf-assets` as the asset root.
  "name": "realworld-taskflow",
  "compatibility_date": "2024-09-23",
  "assets": {
    "directory": "./.cf-assets"
  }
}
